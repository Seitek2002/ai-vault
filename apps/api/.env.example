# Database
DATABASE_URL=postgresql://aivault:aivault@localhost:5432/aivault

# JWT (generate random 64-char hex strings)
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# MinIO / S3 (docker-compose defaults)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-vault
MINIO_PUBLIC_URL=http://localhost:9000

# Anthropic (for AI editing and import structuring)
ANTHROPIC_API_KEY=sk-ant-...

# PDF export — path to local Chrome/Chromium (defaults to standard install locations)
# Windows default: C:\Program Files\Google\Chrome\Application\chrome.exe
# Mac default: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux default: /usr/bin/google-chrome-stable
# CHROME_PATH=

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000
